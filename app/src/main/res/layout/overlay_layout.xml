<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_background"
    android:padding="6dp"
    android:alpha="0.85"
    android:minWidth="220dp"
    android:maxWidth="300dp">

    <!-- ===== HEADER: Game time + Nexus status ===== -->
    <LinearLayout
        android:id="@+id/overlay_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp"
        android:layout_marginBottom="4dp"
        android:background="#18FFD700">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORACLE"
            android:textColor="#FFD700"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/timer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#BBBBBB"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/nexus_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="8sp" />
    </LinearLayout>

    <!-- ===== MY HERO: Stats grid ===== -->
    <LinearLayout
        android:id="@+id/my_hero_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#22FFD700"
        android:padding="4dp"
        android:layout_marginBottom="4dp">

        <!-- Hero name + role -->
        <TextView
            android:id="@+id/my_hero_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- KDA + Gold row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/my_kda"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/my_gold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD700"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Damage + CS row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/my_damage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#FF5722"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/my_cs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#8BC34A"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Item slots (6 items) -->
        <LinearLayout
            android:id="@+id/my_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCCC"
                android:textSize="7sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== ENEMY SUMMARY: 5 rows ===== -->
    <TextView
        android:id="@+id/enemies_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENEMIES"
        android:textColor="#FF5722"
        android:textSize="8sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="2dp" />

    <!-- Enemy 1 -->
    <LinearLayout
        android:id="@+id/enemy1_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#11FF5722"
        android:layout_marginBottom="1dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/enemy1_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FF8A65"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/enemy1_kda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/enemy1_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="7sp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/enemy1_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="6sp"
            android:layout_marginStart="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Enemy 2 -->
    <LinearLayout
        android:id="@+id/enemy2_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#11FF5722"
        android:layout_marginBottom="1dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/enemy2_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FF8A65"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/enemy2_kda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/enemy2_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="7sp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/enemy2_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="6sp"
            android:layout_marginStart="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Enemy 3 -->
    <LinearLayout
        android:id="@+id/enemy3_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#11FF5722"
        android:layout_marginBottom="1dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/enemy3_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FF8A65"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/enemy3_kda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/enemy3_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="7sp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/enemy3_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="6sp"
            android:layout_marginStart="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Enemy 4 -->
    <LinearLayout
        android:id="@+id/enemy4_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#11FF5722"
        android:layout_marginBottom="1dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/enemy4_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FF8A65"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/enemy4_kda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/enemy4_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="7sp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/enemy4_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="6sp"
            android:layout_marginStart="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Enemy 5 -->
    <LinearLayout
        android:id="@+id/enemy5_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#11FF5722"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/enemy5_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FF8A65"
            android:textSize="8sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/enemy5_kda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/enemy5_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="7sp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/enemy5_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="6sp"
            android:layout_marginStart="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- ===== QUICK TIPS: Objective, Team Fight, Equipment ===== -->
    <LinearLayout
        android:id="@+id/suggestion_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#224CAF50"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIPS"
            android:textColor="#4CAF50"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/suggestion_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="7sp"
            android:lineSpacingExtra="1dp" />
    </LinearLayout>

</LinearLayout>
